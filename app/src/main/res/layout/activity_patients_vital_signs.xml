<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FB"
    tools:context=".PatientsVitalSigns">

    <!-- ✅ Background Heartbeat Watermark -->
    <ImageView
        android:id="@+id/bgWatermarkVitals"
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:src="@drawable/baseline_monitor_heart_24"
        android:alpha="0.10"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/heart_icon" />

    <!-- ✅ Foreground Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollViewVitals"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnDashboard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Title -->
            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Enter Patient's Vital Signs"
                android:textColor="#2C3E50"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- Input Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/vitalsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <EditText
                        android:id="@+id/patientHeartRate"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edittext_bg"
                        android:hint="Heart Rate (bpm)"
                        android:inputType="number"
                        android:padding="12dp"
                        android:textColor="#2C3E50"
                        android:textColorHint="#A0A0A0" />

                    <EditText
                        android:id="@+id/patientBloodPressure"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edittext_bg"
                        android:hint="Blood Pressure (e.g., 120/80)"
                        android:inputType="text"
                        android:padding="12dp"
                        android:textColor="#2C3E50"
                        android:textColorHint="#A0A0A0" />

                    <EditText
                        android:id="@+id/patientCholesterol"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/edittext_bg"
                        android:hint="Cholesterol (mg/dL)"
                        android:inputType="number"
                        android:padding="12dp"
                        android:textColor="#2C3E50"
                        android:textColorHint="#A0A0A0" />

                    <!-- Symptoms Selection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Symptoms:"
                        android:textColor="#2C3E50"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnSelectSymptoms"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Choose Symptoms"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/edittext_bg" />

                    <TextView
                        android:id="@+id/tvSelectedSymptoms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No symptoms selected"
                        android:textColor="#7F8C8D"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:padding="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Vital Signs -->
            <Button
                android:id="@+id/btnVitalSignsNext"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#2E86DE"
                android:text="Save Vital Signs"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </ScrollView>

    <!-- ✅ Dashboard Button (Outlined Blue, Pinned to Bottom) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDashboard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Dashboard"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#2E86DE"
        app:cornerRadius="12dp"
        app:strokeColor="#2E86DE"
        app:strokeWidth="2dp"
        app:backgroundTint="#FFFFFF"
        android:elevation="4dp"
        android:paddingVertical="14dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
