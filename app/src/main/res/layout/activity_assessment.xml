<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    tools:context=".AssessmentActivity">

    <!-- ✅ Background Heartbeat Watermark -->
    <ImageView
        android:id="@+id/bgWatermarkAssessment"
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:src="@drawable/baseline_monitor_heart_24"
        android:alpha="0.10"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/heart_icon" />

    <!-- ✅ Foreground Scroll Content -->
    <ScrollView
        android:id="@+id/scrollViewAssessment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnDashboard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Section: Assessment Header -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Risk Assessment"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1E3A8A"
                android:layout_marginBottom="12dp" />

            <!-- Section: Patient Info Preview -->
            <TextView
                android:id="@+id/tvInputsPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(Patient inputs will appear here)"
                android:textSize="15sp"
                android:textColor="#333333"
                android:background="@drawable/rounded_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp" />

            <!-- Section: Generate Button -->
            <Button
                android:id="@+id/btnGenerateAssessment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Generate Assessment"
                android:background="@drawable/rounded_button"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:layout_marginBottom="20dp" />

            <!-- Section: Risk Result -->
            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Risk: -"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E3A8A"
                android:layout_marginBottom="20dp" />

            <!-- Section: View History Block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_history"
                    android:tint="#1E3A8A" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Assessment History"
                        android:textColor="#1E3A8A"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See your previous results and track changes."
                        android:textColor="#666"
                        android:textSize="13sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnViewHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open"
                    android:background="@drawable/rounded_button_outline"
                    android:textColor="#1E3A8A"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ✅ Dashboard Button (Moved to Bottom, New Color) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDashboard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Dashboard"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#2E86DE"
        app:cornerRadius="12dp"
        app:strokeColor="#2E86DE"
        app:strokeWidth="2dp"
        app:backgroundTint="#FFFFFF"
        android:elevation="4dp"
        android:paddingVertical="14dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
