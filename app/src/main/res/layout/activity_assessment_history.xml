<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FB"
    tools:context=".AssessmentHistoryActivity">

    <!-- ✅ Background Heartbeat Watermark -->
    <ImageView
        android:id="@+id/bgWatermarkHistory"
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:src="@drawable/baseline_monitor_heart_24"
        android:alpha="0.10"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/heart_icon" />

    <!-- ✅ Foreground Content -->
    <LinearLayout
        android:id="@+id/foregroundLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 🩺 Header -->
        <TextView
            android:id="@+id/tvAssessmentTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Assessment History"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1E3A8A"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 📋 Assessment List Container -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            android:backgroundTint="#FFFFFF">

            <ListView
                android:id="@+id/listAssessments"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#E0E0E0"
                android:dividerHeight="1dp"
                android:padding="12dp"
                android:clipToPadding="false"
                android:scrollbars="vertical" />
        </androidx.cardview.widget.CardView>

        <!-- 🔙 Back Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textAllCaps="false"
            android:textColor="#2E86DE"
            android:textStyle="bold"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:strokeColor="#2E86DE"
            app:strokeWidth="2dp"
            app:backgroundTint="#FFFFFF"
            android:layout_marginTop="8dp"
            android:padding="12dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
