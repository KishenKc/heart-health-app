<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".Dashboard">

    <!-- ✅ Background Heartbeat Watermark (centered & visible behind content) -->
    <ImageView
        android:id="@+id/bgWatermark"
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:src="@drawable/baseline_monitor_heart_24"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/heart_icon" />

    <!-- HEADER SECTION -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="160dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@drawable/bg_header_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Welcome 👋"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:shadowColor="#33000000"
            android:shadowDx="2"
            android:shadowDy="3"
            android:shadowRadius="6"
            android:letterSpacing="0.02"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="start|center_vertical"
            android:paddingEnd="12dp" />

        <ImageButton
            android:id="@+id/btnProfileDash"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_profile_icon"
            android:src="@drawable/ic_profile"
            android:padding="10dp"
            android:contentDescription="Profile" />
    </LinearLayout>

    <!-- MAIN CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@+id/btnAIHealthAssistant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="true"
            android:padding="16dp">

            <!-- CARD: Patient Info -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnHealth"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_health_summary"
                        android:tint="#007AFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Patient Info"
                        android:textSize="16sp"
                        android:textColor="#1A2E35"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: Vital Signs -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnVital"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_vitals"
                        android:tint="#007AFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Vital Signs"
                        android:textSize="16sp"
                        android:textColor="#1A2E35"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: Risk Assessment -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnRiskAssessment"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_assessment"
                        android:tint="#FF6B6B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Risk Assessment"
                        android:textSize="16sp"
                        android:textColor="#1A2E35"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: View History -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnHistory"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_history"
                        android:tint="#007AFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="View History"
                        android:textSize="16sp"
                        android:textColor="#1A2E35"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>
    </ScrollView>

    <!-- AI HEART HEALTH ASSISTANT BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAIHealthAssistant"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="💬  AI Heart Health Assistant"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="17sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#007AFF"
        app:cornerRadius="16dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="88dp"
        app:layout_constraintBottom_toTopOf="@id/btnLogoutDash"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- LOGOUT BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogoutDash"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="LOGOUT"
        android:textColor="#FF4C4C"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
