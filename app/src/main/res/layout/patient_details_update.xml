<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:padding="24dp"
    tools:context=".PatientDetailsUpdate">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- HEADER -->

        <!-- Question 1 -->
        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="12dp"
            android:text="Heart Risk Questionnaire"
            android:textColor="#2C3E50"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Do you smoke?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="12dp" />
        <Spinner
            android:id="@+id/spnSmoke"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Question 2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Do you drink alcohol regularly?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
        <Spinner
            android:id="@+id/spnAlcohol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Question 3 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. Do you exercise at least 3 times a week?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
        <Spinner
            android:id="@+id/spnExercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Question 4 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4. Is your diet mostly healthy?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
        <Spinner
            android:id="@+id/spnDiet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Question 5 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5. Do you have high blood pressure?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
        <Spinner
            android:id="@+id/spnBP"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Question 6 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6. Do you have high cholesterol?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
        <Spinner
            android:id="@+id/spnCholesterol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Question 7 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7. Do you have diabetes?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
        <Spinner
            android:id="@+id/spnDiabetes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Question 8 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8. Does anyone in your family have heart disease?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
        <Spinner
            android:id="@+id/spnFamily"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Question 9 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9. Do you often feel stressed or anxious?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
        <Spinner
            android:id="@+id/spnStress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Question 10 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10. Have you ever felt chest pain or tightness?"
            android:textColor="#34495E"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
        <Spinner
            android:id="@+id/spnChestPain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown" />

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdateAnswers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Save / Update Answers"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="#3498DB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Back to Dashboard"
            android:textAllCaps="false"
            android:textColor="#3498DB"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="#FFFFFF"
            app:strokeColor="#3498DB"
            app:strokeWidth="2dp"/>

    </LinearLayout>
</ScrollView>
