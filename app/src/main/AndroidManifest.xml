<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🌐 Internet permission for Supabase API calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication_java"
        tools:targetApi="31">

        <!-- 🚀 Launch Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🔐 Authentication Activities -->
        <activity android:name=".Login" android:exported="false" />
        <activity android:name=".Register" android:exported="false" />

        <!-- 🏠 Main User Dashboard -->
        <activity android:name=".Dashboard" android:exported="true" />

        <!-- 👤 Profile Section -->
        <activity android:name=".ProfileDetails" android:exported="false" />
        <activity android:name=".ViewProfile" android:exported="false" />

        <!-- 🧍 Patient Management -->
        <activity android:name=".PatientDetailsUpdate" android:exported="false" />
        <activity android:name=".PatientsActivity" android:exported="false" />
        <activity android:name=".PatientsVitalSigns" android:exported="false" />
        <activity android:name=".LastAssessment" android:exported="false" />
        <activity android:name=".RecentVital" android:exported="false" />

        <!-- 📊 Assessment & History -->
        <activity android:name=".AssessmentHistoryActivity" android:exported="false" />
        <activity android:name=".History" android:exported="false" />

        <!-- 🤖 AI & Chat Features -->
        <activity android:name=".ChatBot" android:exported="false" />
        <activity android:name=".AIresult" android:exported="false" />
        <activity android:name=".Result" android:exported="false" />

        <!-- ❤️ Risk Assessment Screen -->
        <activity
            android:name=".AssessmentActivity"
            android:label="Risk Assessment"
            android:exported="false"
            android:parentActivityName=".Dashboard">
            <!-- Enable Back Navigation -->
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".Dashboard" />
        </activity>

    </application>
</manifest>
